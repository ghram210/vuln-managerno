        h2 { border-right: 6px solid #1a365d; padding-right: 20px; background: #f7fafc; padding-top: 12px; padding-bottom: 12px; font-size: 2em; }
        h3 { font-size: 1.6em; color: #2c5282; border-bottom: 1px solid #e2e8f0; padding-bottom: 5px; }
        h4 { font-size: 1.3em; color: #2b6cb0; }
