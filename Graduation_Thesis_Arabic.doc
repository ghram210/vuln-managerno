        }

        .difficulty-box {
            background: #fff5f5;
            border-right: 5px solid #e53e3e;
            padding: 20px;
            margin: 25px 0;
            border-radius: 0 8px 8px 0;
        }

        .requirement-section {
            background: #fffaf0;
            border-right: 5px solid #dd6b20;
            padding: 20px;
            margin: 25px 0;
            border-radius: 0 8px 8px 0;
        }

