            padding: 0;
            background-color: var(--bg);
        }

        .cover-page {
            text-align: center;
            padding: 120px 50px;
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            color: white;
            min-height: 80vh;
            display: flex;
