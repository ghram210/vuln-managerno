            justify-content: center;
            border-bottom: 10px solid var(--accent);
        }

        .cover-page h1 { font-size: 3.5em; margin-bottom: 20px; color: var(--accent); text-shadow: 2px 2px 4px rgba(0,0,0,0.3); }
        .cover-page h2 { font-size: 1.8em; font-weight: 300; opacity: 0.9; margin-bottom: 50px; }
        .cover-details { font-size: 1.2em; border-top: 1px solid rgba(255,255,255,0.2); padding-top: 30px; display: inline-block; }

        .content-wrapper { padding: 40px; }

        .toc {
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            margin-bottom: 50px;
            border-right: 8px solid var(--primary);
        }

        .toc h3 {
            font-size: 2em;
            color: var(--secondary);
            border-bottom: 2px solid #e2e8f0;
            padding-bottom: 15px;
            margin-bottom: 25px;
            text-align: center;
        }

        .toc-list { list-style: none; padding: 0; }
        .toc-item { margin: 15px 0; }
        .toc-link {
            text-decoration: none;
            color: var(--secondary);
            font-weight: 600;
            font-size: 1.1em;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px;
            border-radius: 8px;
            transition: background 0.3s;
        }
        .toc-link:hover { background: #f1f5f9; color: var(--primary); }
        .toc-link span { color: #94a3b8; font-weight: normal; font-size: 0.9em; }

        .toc-sublist { list-style: none; padding-right: 30px; margin-top: 10px; }
        .toc-subitem { margin: 8px 0; border-right: 2px solid #e2e8f0; padding-right: 15px; }
        .toc-sublink { text-decoration: none; color: #64748b; font-size: 1em; transition: color 0.3s; }
        .toc-sublink:hover { color: var(--accent); }

        .section {
            background: white;
            padding: 60px;
            border-radius: 15px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            margin-bottom: 50px;
            page-break-after: always;
        }

        h2 {
            color: var(--secondary);
            font-size: 2.2em;
            border-right: 8px solid var(--accent);
            padding-right: 20px;
            margin-bottom: 40px;
            background: #f8fafc;
            padding: 15px 20px;
            border-radius: 0 10px 10px 0;
        }

        h3 { color: var(--primary); font-size: 1.6em; margin-top: 40px; border-bottom: 1px solid #f1f5f9; padding-bottom: 10px; }
        h4 { color: #1e293b; font-size: 1.3em; margin-top: 30px; background: #f1f5f9; padding: 10px 20px; border-radius: 8px; }

        p { text-align: justify; margin-bottom: 20px; }

        .highlight-box {
            background: #f0f7ff;
            border-right: 5px solid var(--primary);
            padding: 30px;
            margin: 30px 0;
            border-radius: 0 12px 12px 0;
            font-style: italic;
            box-shadow: inset 0 0 10px rgba(37,99,235,0.05);
        }

        .tool-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 30px; }
        .tool-card {
            border: 1px solid #e2e8f0;
            padding: 25px;
            border-radius: 12px;
            background: #ffffff;
            transition: transform 0.3s, box-shadow 0.3s;
        }
        .tool-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
        .tool-card h4 { margin-top: 0; background: var(--primary); color: white; }

        .footer { text-align: center; padding: 40px; color: #94a3b8; border-top: 1px solid #e2e8f0; margin-top: 50px; }

        @media print {
            body { background: white; }
            .content-wrapper { padding: 0; }
            .section { box-shadow: none; border: none; padding: 40px 0; }
            .cover-page { height: 100vh; }
            .no-print { display: none; }
        }
    </style>
</head>
<body>

    <!-- Cover Page -->
    <div class="cover-page">
        <h1>منصة ذكية مؤتمتة لإدارة الثغرات واستخبارات التهديدات</h1>
        <h2>بحث تخرج مقدم لنيل درجة البكالوريوس في هندسة البرمجيات والأمن السيبراني</h2>
        <div class="cover-details">
            <p>إعداد الطالب: <strong>[اسمك الكريم هنا]</strong></p>
