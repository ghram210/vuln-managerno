            line-height: 1.6;
            margin: 40px;
            color: #333;
        }
        h1, h2, h3 {
            color: #2c3e50;
            border-bottom: 2px solid #eee;
            padding-bottom: 10px;
        }
        .highlight {
            background-color: #f8f9fa;
            border-right: 5px solid #007bff;
            padding: 15px;
            margin: 20px 0;
        }
        .question {
            font-weight: bold;
            color: #d9534f;
        }
        .answer {
            margin-bottom: 20px;
            padding-right: 20px;
        }
        .code-block {
            background-color: #2d3436;
            color: #dfe6e9;
            padding: 15px;
            border-radius: 5px;
            font-family: 'Courier New', Courier, monospace;
            direction: ltr;
            text-align: left;
            margin: 10px 0;
            overflow-x: auto;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
        }
