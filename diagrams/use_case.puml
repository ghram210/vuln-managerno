@startuml
left to right direction
skinparam packageStyle rectangle

actor "محلل أمني (Security User)" as user
actor "مدير النظام (Admin)" as admin

rectangle "نظام إدارة الثغرات المتكامل" {
    usecase "تسجيل الدخول / المصادقة" as login
    usecase "عرض لوحة المعلومات (Dashboard)" as view_dashboard
    usecase "عرض وتحليل الثغرات" as view_vulns
    usecase "مراقبة حالة الفحص (Monitoring)" as monitor_scans

    usecase "إدارة الأصول والأهداف" as manage_assets
    usecase "بدء فحص جديد (New Scan)" as start_scan
    usecase "توليد تقارير أمنية (Reports)" as generate_reports
    usecase "إدارة المستخدمين والصلاحيات" as manage_users
    usecase "إعدادات النظام والتنبيهات" as system_settings
}

' Security User Permissions (Read-Only)
user --> login
user --> view_dashboard
user --> view_vulns
user --> monitor_scans

' Admin inherits from User and adds Management permissions
admin --|> user
admin --> manage_assets
admin --> start_scan
admin --> generate_reports
admin --> manage_users
admin --> system_settings

@enduml
